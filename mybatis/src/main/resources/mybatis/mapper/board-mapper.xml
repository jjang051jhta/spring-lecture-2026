<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jjang051.mybatis.board.dao.BoardDao">
    <insert id="writeBoard" parameterType="BoardDto">
        INSERT INTO NEW_BOARD (no,title,content) VALUES
        (NEW_BOARD_SEQ.nextval,#{title},#{content})
    </insert>
</mapper>

