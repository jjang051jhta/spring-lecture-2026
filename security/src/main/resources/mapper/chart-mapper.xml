<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jjang051.security.chart.dao.ChartDao">
    <select id="findChinaMenu" resultType="ChartDto">
        SELECT menu AS label,sum(cnt) AS value FROM china_menu GROUP BY menu
    </select>
</mapper>

