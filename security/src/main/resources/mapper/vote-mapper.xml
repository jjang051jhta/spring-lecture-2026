<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jjang051.security.vote.dao.VoteDao">
    <select id="findAllVotes" parameterType="int" resultType="VoteDto">
        SELECT * FROM VOTE ORDER BY vote_no DESC
    </select>
    <select id="findVoteByNo" parameterType="int" resultType="VoteDto">
        SELECT * FROM VOTE WHERE vote_no = #{voteNo}
    </select>
    <select id="findItemsByVoteNo" parameterType="int" resultType="VoteItemDto">
        SELECT * FROM vote_item
        WHERE vote_no = #{voteNo}
        ORDER BY item_no asc
    </select>
    <update id="increaseVoteCount" parameterType="int">
        UPDATE vote_item SET vote_count = vote_count+1  WHERE item_no = #{itemNo}
    </update>
    <insert id="insertVote" parameterType="VoteDto">
        <selectKey keyProperty="voteNo" resultType="int" order="BEFORE">
            SELECT vote_seq.nextval FROM DUAL
        </selectKey>
        INSERT INTO vote
            (vote_no,title,reg_date) VALUES
        (#{voteNo},#{title},SYSDATE)
    </insert>
    <insert id="insertVoteItem">
        INSERT INTO vote_item
        (item_no,vote_no,item_text,vote_count) VALUES
        (vote_item_seq.nextval,#{voteNo},#{itemText},0)
    </insert>
</mapper>

