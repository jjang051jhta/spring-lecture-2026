<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jjang051.security.vote.dao.VoteDao">
    <select id="findAllVotes" parameterType="int" resultType="VoteDto">
        SELECT * FROM VOTE ORDER BY vote_no DESC
    </select>
    <select id="findVoteByNo" parameterType="int" resultType="VoteDto">
        SELECT * FROM VOTE WHERE vote_no = #{voteNo}
    </select>
    <select id="findItemsByVoteNo" parameterType="int" resultType="VoteItemDto">
        SELECT * FROM vote_item
        WHERE vote_no = #{voteNo}
        ORDER BY item_no asc
    </select>
    <update id="increaseVoteCount" parameterType="int">
        UPDATE vote_item SET vote_count = vote_count+1  WHERE item_no = #{itemNo}
    </update>
</mapper>

